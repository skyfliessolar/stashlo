<!-- HEADER -->
<header class="header">
  <div class="header-wrap">
    <div class="logo">Stashlo</div>
    <nav>
      <ul class="nav-links">
        <li><a href="#features">Features</a></li>
        <li><a href="#benefits">Benefits</a></li>
