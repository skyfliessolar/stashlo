<div class="modal" id="appModal">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <h2 style="margin-bottom: 10px;">Which app are you?</h2>
    <p style="color: var(--text-muted); margin-bottom: 20px;">Select your role to get started.</p>
    <div class="app-selector">
      <div class="app-option" onclick="selectApp('customer')">
        <div class="app-option-icon">👤</div>
        <div class="app-option-text">I'm a Customer</div>
      </div>
      <div class="app-option" onclick="selectApp('merchant')">
        <div class="app-option-icon">🏪</div>
        <div class="app-option-text">I'm a Merchant</div>
      </div>
    </div>
    <button class="btn btn-primary" style="width: 100%; margin-top: 24px; padding: 14px;" onclick="confirmSelection()">
      Continue
    </button>
  </div>
</div>

<script>
  let selectedApp = null;

  function showAppSelector() {
    document.getElementById('appModal').classList.add('show');
  }

  function closeModal() {
    document.getElementById('appModal').classList.remove('show');
    selectedApp = null;
  }

  function selectApp(app) {
    selectedApp = app;
    document.querySelectorAll('.app-option').forEach(el => el.classList.remove('selected'));
    event.target.closest('.app-option').classList.add('selected');
  }

  function confirmSelection() {
    if (!selectedApp) {
      alert('Please select an option');
      return;
    }
    if (selectedApp === 'customer') {
      window.location.href = 'https://skyfliessolar.github.io/stashlo/';
    } else if (selectedApp === 'merchant') {
      openMerchantApp();
    }
  }

  function openMerchantApp() {
    window.location.href = 'https://skyfliessolar.github.io/stashlo/merchant.html';
  }

  function openAdminApp() {
    window.location.href = 'https://skyfliessolar.github.io/stashlo/admin.html';
  }

  function scrollToDownload() {
    document.getElementById('download').scrollIntoView({ behavior: 'smooth' });
  }

  // Smooth scroll for nav links
  document.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener('click', function(e) {
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });

  // Check if user is on mobile and visiting from merchant link
  if (new URLSearchParams(window.location.search).get('app') === 'merchant') {
    setTimeout(() => openMerchantApp(), 500);
  }
</script>

