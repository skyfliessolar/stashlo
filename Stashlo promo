<!DOCTYPE html>
<html lang="en"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>Stashlo — the receipt that never fades</title>
<style>
:root{
  --ink:#14121F; --paper:#FAF7F2; --deep:#1e1b4b; --mid:#312e81;
  --purple:#6366F1; --gold:#FBBF24; --sky:#0EA5E9;
  --mono:ui-monospace,'SF Mono',Menlo,Consolas,'Courier New',monospace;
  --sans:-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;overflow:hidden;background:var(--deep);font-family:var(--sans);color:#fff;-webkit-font-smoothing:antialiased}
.stage{position:fixed;inset:0;display:grid;place-items:center;padding:5vmin}
.slide{position:absolute;inset:0;display:grid;place-items:center;padding:6vmin;opacity:0;pointer-events:none;transition:opacity .6s ease}
.slide.on{opacity:1;pointer-events:auto}
.wrap{width:min(94vw,1000px);text-align:center}
.eyebrow{font-family:var(--mono);font-size:clamp(10px,1.5vmin,13px);letter-spacing:.32em;text-transform:uppercase;color:#a5b4fc;margin-bottom:2.5vmin}
h1{font-size:clamp(34px,7.4vmin,74px);font-weight:900;letter-spacing:-.035em;line-height:.98}
h2{font-size:clamp(26px,5.2vmin,50px);font-weight:900;letter-spacing:-.03em;line-height:1.04}
p.lead{font-size:clamp(14px,2.3vmin,21px);color:#c7d2fe;margin-top:2.5vmin;line-height:1.5;max-width:34ch;margin-left:auto;margin-right:auto}
/* ── signature: the printing receipt ── */
.receipt{background:var(--paper);color:var(--ink);width:min(78vw,320px);margin:0 auto;padding:5vmin 4vmin 6vmin;font-family:var(--mono);font-size:clamp(11px,1.9vmin,14px);text-align:left;line-height:1.85;
  box-shadow:0 24px 60px rgba(0,0,0,.45);position:relative;
  clip-path:polygon(0 0,100% 0,100% calc(100% - 10px),92% 100%,84% calc(100% - 10px),76% 100%,68% calc(100% - 10px),60% 100%,52% calc(100% - 10px),44% 100%,36% calc(100% - 10px),28% 100%,20% calc(100% - 10px),12% 100%,4% calc(100% - 10px),0 100%);
  transform-origin:top center;animation:feed 1.1s cubic-bezier(.2,.7,.2,1) both}
.receipt .rt{text-align:center;font-weight:700;letter-spacing:.12em}
.receipt hr{border:0;border-top:1px dashed #cbc5bb;margin:2vmin 0}
.receipt .row{display:flex;justify-content:space-between;opacity:0;animation:line .3s ease forwards}
.receipt .row:nth-of-type(1){animation-delay:.7s} .receipt .row:nth-of-type(2){animation-delay:1s}
.receipt .row:nth-of-type(3){animation-delay:1.3s} .receipt .row:nth-of-type(4){animation-delay:1.6s}
.receipt .stamp{margin-top:2.4vmin;text-align:center;font-weight:800;color:#166534;border:2px solid #166534;border-radius:8px;padding:1.4vmin;opacity:0;animation:stamp .5s cubic-bezier(.2,1.5,.4,1) 2.1s forwards;transform:scale(.7) rotate(-4deg)}
@keyframes feed{from{transform:scaleY(.04);opacity:.2}to{transform:scaleY(1);opacity:1}}
@keyframes line{to{opacity:1}}
@keyframes stamp{to{opacity:1;transform:scale(1) rotate(-3deg)}}
/* ── wallet cards ── */
.cards{position:relative;height:min(46vh,320px);margin-top:3vmin}
.lcard{position:absolute;left:50%;width:min(72vw,300px);height:min(20vh,120px);border-radius:18px;padding:3vmin;text-align:left;
  box-shadow:0 18px 44px rgba(0,0,0,.4);transform:translateX(-50%);font-weight:800;animation:deal .7s cubic-bezier(.2,.8,.25,1) both}
.lcard b{display:block;font-size:clamp(13px,2vmin,17px)}
.lcard span{font-family:var(--mono);font-size:clamp(18px,3.4vmin,30px);display:block;margin-top:1vmin}
@keyframes deal{from{opacity:0;transform:translate(-50%,60px) rotate(6deg)}to{opacity:1}}
/* ── counter ── */
.count{font-family:var(--mono);font-size:clamp(56px,15vmin,150px);font-weight:800;color:var(--gold);letter-spacing:-.04em;line-height:1}
.count small{font-size:.32em;color:#c7d2fe;letter-spacing:.2em;display:block;margin-top:1.5vmin;font-family:var(--sans)}
/* ── map ── */
.map{width:min(86vw,520px);height:min(38vh,260px);margin:3vmin auto 0;border-radius:22px;background:
  repeating-linear-gradient(0deg,rgba(255,255,255,.07) 0 1px,transparent 1px 34px),
  repeating-linear-gradient(90deg,rgba(255,255,255,.07) 0 1px,transparent 1px 34px),#241f52;position:relative;overflow:hidden}
.route{position:absolute;left:12%;right:14%;top:62%;height:4px;background:rgba(255,255,255,.22);border-radius:2px}
.van{position:absolute;top:calc(62% - 16px);left:12%;font-size:30px;animation:drive 4.5s cubic-bezier(.5,0,.5,1) infinite}
.home{position:absolute;top:calc(62% - 20px);right:9%;font-size:28px}
@keyframes drive{0%{left:10%}75%{left:74%}100%{left:74%}}
/* ── product tiles ── */
.ptiles{display:grid;grid-template-columns:repeat(4,1fr);gap:2vmin;max-width:min(88vw,660px);margin:3vmin auto 0}
.ptile{width:100%;border-radius:16px;opacity:0;transform:translateY(18px) scale(.94);animation:pop .5s cubic-bezier(.2,1.3,.4,1) forwards;box-shadow:0 12px 28px rgba(0,0,0,.3)}
.ptile:nth-child(1){animation-delay:.1s}.ptile:nth-child(2){animation-delay:.2s}.ptile:nth-child(3){animation-delay:.3s}.ptile:nth-child(4){animation-delay:.4s}
.ptile:nth-child(5){animation-delay:.5s}.ptile:nth-child(6){animation-delay:.6s}.ptile:nth-child(7){animation-delay:.7s}.ptile:nth-child(8){animation-delay:.8s}
@keyframes pop{to{opacity:1;transform:none}}
/* ── till lines ── */
.till{font-family:var(--mono);text-align:left;width:min(86vw,520px);margin:3vmin auto 0;background:rgba(0,0,0,.28);border-radius:18px;padding:4vmin;font-size:clamp(12px,2vmin,16px);line-height:2}
.till div{opacity:0;animation:line .35s ease forwards}
.till div:nth-child(1){animation-delay:.3s}.till div:nth-child(2){animation-delay:.9s}.till div:nth-child(3){animation-delay:1.5s}.till div:nth-child(4){animation-delay:2.1s}
.say{color:var(--gold)} .did{color:#86efac}
/* ── CTA ── */
.qrs{display:flex;gap:4vmin;justify-content:center;flex-wrap:wrap;margin-top:4vmin}
.qrcard{background:#fff;border-radius:22px;padding:3vmin;width:min(40vw,240px);box-shadow:0 20px 50px rgba(0,0,0,.45)}
.qrcard img{width:100%;display:block;border-radius:10px}
.qrcard b{display:block;color:var(--ink);font-size:clamp(13px,2vmin,17px);margin-top:1.6vmin}
.qrcard span{display:block;font-family:var(--mono);font-size:clamp(10px,1.5vmin,12px);color:#6366F1;margin-top:.6vmin}
.free{display:inline-block;background:var(--gold);color:var(--deep);font-weight:900;border-radius:10px;padding:1.4vmin 2.6vmin;margin-top:3.5vmin;font-size:clamp(12px,2vmin,17px);transform:rotate(-1.4deg)}
/* ── chrome ── */
.dots{position:fixed;bottom:2.4vmin;left:0;right:0;display:flex;gap:9px;justify-content:center;z-index:5}
.dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.28);transition:.3s;cursor:pointer}
.dot.on{background:var(--gold);width:26px;border-radius:4px}
.brand{position:fixed;top:2.6vmin;left:3vmin;font-weight:900;font-size:clamp(15px,2.2vmin,20px);z-index:5;letter-spacing:-.02em}
.hint{position:fixed;bottom:2.4vmin;right:3vmin;font-family:var(--mono);font-size:11px;color:rgba(199,210,254,.5);z-index:5}
.bg{position:fixed;inset:0;background:radial-gradient(1100px 620px at 50% 12%,#3b3596 0%,transparent 62%),linear-gradient(165deg,#1e1b4b,#0f0d2b 88%)}
@media (prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}.ptile,.receipt .row,.receipt .stamp,.till div{opacity:1!important;transform:none!important}}
</style></head><body>
<div class="bg"></div>
<div class="brand">💜 Stashlo</div>
<div class="stage">

  <section class="slide on"><div class="wrap">
    <div class="eyebrow">Bristol · local shops</div>
    <div class="receipt">
      <div class="rt">CORNER SHOP<br>BRISTOL</div><hr>
      <div class="row"><span>Milk 2L</span><b>£1.45</b></div>
      <div class="row"><span>Bread</span><b>£1.10</b></div>
      <div class="row"><span>Coffee</span><b>£3.20</b></div>
      <div class="row"><span>TOTAL</span><b>£5.75</b></div>
      <hr><div class="stamp">+57 POINTS · SAVED FOREVER</div>
    </div>
    <h2 style="margin-top:4vmin">The receipt that<br>never fades.</h2>
  </div></section>

  <section class="slide"><div class="wrap">
    <div class="eyebrow">One wallet</div>
    <h2>Every shop's points.<br>One screen.</h2>
    <div class="cards">
      <div class="lcard" style="top:0;background:linear-gradient(135deg,#6366F1,#4338ca);animation-delay:.15s"><b>☕ Corner Café</b><span>340 pts</span></div>
      <div class="lcard" style="top:31%;background:linear-gradient(135deg,#0EA5E9,#0369a1);animation-delay:.35s"><b>⛽ Skyflies Forecourt</b><span>1,205 pts</span></div>
      <div class="lcard" style="top:62%;background:linear-gradient(135deg,#10b981,#065f46);animation-delay:.55s"><b>🥖 High St Bakery</b><span>88 pts</span></div>
    </div>
  </div></section>

  <section class="slide"><div class="wrap">
    <div class="eyebrow">Points become money off</div>
    <div class="count" id="ctr">0<small>POINTS = £12.05 OFF</small></div>
    <p class="lead">Earn in the shop, on collection, on delivery. Spend them at the checkout like cash.</p>
  </div></section>

  <section class="slide"><div class="wrap">
    <div class="eyebrow">Live delivery</div>
    <h2>Watch it come<br>to your door.</h2>
    <div class="map"><div class="route"></div><div class="van">🛵</div><div class="home">🏠</div></div>
    <p class="lead">Your driver on the map, updating every few seconds — from your own local shop.</p>
  </div></section>

  <section class="slide"><div class="wrap">
    <div class="eyebrow">Stashlo store</div>
    <h2>Order it. Collect it.<br>Earn on it.</h2>
    <div class="ptiles"><img class="ptile" src="data:image/svg+xml;base64," alt="headphones"><img class="ptile" src="data:image/svg+xml;base64," alt="earbuds"><img class="ptile" src="data:image/svg+xml;base64," alt="speaker"><img class="ptile" src="data:image/svg+xml;base64," alt="charger"><img class="ptile" src="data:image/svg+xml;base64," alt="powerbank"><img class="ptile" src="data:image/svg+xml;base64," alt="watch"><img class="ptile" src="data:image/svg+xml;base64," alt="bulb"><img class="ptile" src="data:image/svg+xml;base64," alt="cable"></div>
    <p class="lead">Everyday essentials and gadgets — delivered or collected, points on every order.</p>
  </div></section>

  <section class="slide"><div class="wrap">
    <div class="eyebrow">For shop owners</div>
    <h2>Talk to your till.</h2>
    <div class="till">
      <div class="say">🎤 "ten pound diesel, cash twenty"</div>
      <div class="did">✓ Diesel £10.00 · change £10.00</div>
      <div class="did">✓ E-receipt sent · +10 points</div>
      <div class="did">✓ Z-report &amp; VAT ready for your accountant</div>
    </div>
    <p class="lead">Free EPOS on the phone you own. Keep your card machine, keep your other till — Stashlo exports the lot as one tax file.</p>
  </div></section>

  <section class="slide"><div class="wrap">
    <div class="eyebrow">Scan · no app store</div>
    <h1>Start in<br>10 seconds.</h1>
    <div class="qrs">
      <div class="qrcard"><img src="data:image/png;base64," alt="Customer QR"><b>I'm a shopper</b><span>stashlo.com</span></div>
      <div class="qrcard"><img src="data:image/png;base64," alt="Merchant QR"><b>I own a shop</b><span>stashlo.com/merchant</span></div>
    </div>
    <div class="free">Free · opens straight in your browser</div>
  </div></section>
</div>
<div class="dots" id="dots"></div>
<div class="hint">tap / → to move · space pauses</div>
<script>
const slides=[...document.querySelectorAll('.slide')],dots=document.getElementById('dots');
let i=0,timer=null,paused=false;
slides.forEach((_,n)=>{const d=document.createElement('div');d.className='dot'+(n?'':' on');d.onclick=e=>{e.stopPropagation();go(n)};dots.appendChild(d)});
function restartAnim(el){el.querySelectorAll('.receipt,.lcard,.ptile,.till div,.van,.receipt .row,.receipt .stamp').forEach(n=>{n.style.animation='none';n.offsetHeight;n.style.animation='';});}
function go(n){
  slides[i].classList.remove('on');dots.children[i].classList.remove('on');
  i=(n+slides.length)%slides.length;
  slides[i].classList.add('on');dots.children[i].classList.add('on');
  restartAnim(slides[i]);
  if(i===2)runCounter();
  schedule();
}
function schedule(){clearTimeout(timer);if(!paused)timer=setTimeout(()=>go(i+1),i===0?7500:7000);}
function runCounter(){
  const el=document.getElementById('ctr'),end=1205;let v=0,t0=null;
  function step(ts){if(!t0)t0=ts;const p=Math.min((ts-t0)/1400,1);v=Math.round(end*(1-Math.pow(1-p,3)));
    el.innerHTML=v.toLocaleString()+'<small>POINTS = £12.05 OFF</small>';if(p<1)requestAnimationFrame(step);}
  requestAnimationFrame(step);
}
document.body.onclick=()=>go(i+1);
document.onkeydown=e=>{
  if(e.key==='ArrowRight')go(i+1); else if(e.key==='ArrowLeft')go(i-1);
  else if(e.key===' '){e.preventDefault();paused=!paused;paused?clearTimeout(timer):schedule();}
};
let sx=0;document.addEventListener('touchstart',e=>sx=e.touches[0].clientX,{passive:true});
document.addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-sx;if(Math.abs(dx)>50)go(dx<0?i+1:i-1)},{passive:true});
schedule();
</script></body></html>
