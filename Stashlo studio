function exportPNG(mult){
  const c=document.createElement('canvas');c.width=W*mult;c.height=H*mult;
  const g=c.getContext('2d');g.scale(mult,mult);
  g.fillStyle=BG;g.fillRect(0,0,W,H);
  const jobs=EL.map(e=>()=>new Promise(res=>{
    const w=e.w||(e.t==='sticker'?e.size:100), hh=e.h||(e.t==='sticker'?e.size:(e.t==='text'?e.size*1.2:100));
    g.save();
    if(e.op!==undefined)g.globalAlpha=e.op;
    if(e.shadow){g.shadowColor='rgba(0,0,0,.45)';g.shadowBlur=18;g.shadowOffsetY=8;}
    if(e.rot){g.translate(e.x+w/2,e.y+hh/2);g.rotate(e.rot*Math.PI/180);g.translate(-(e.x+w/2),-(e.y+hh/2));}
    const done=res; res=()=>{g.restore();done();};
    if(e.t==='rect'){g.fillStyle=e.fill;rr(g,e.x,e.y,e.w,e.h,e.r||0);g.fill();res();}
    else if(e.t==='circle'){g.fillStyle=e.fill;g.beginPath();g.ellipse(e.x+e.w/2,e.y+e.h/2,e.w/2,e.h/2,0,0,7);g.fill();res();}
    else if(e.t==='text'){g.fillStyle=e.color;g.textBaseline='top';
      g.font=(e.weight||700)+' '+e.size+'px '+(e.font==='mono'?'monospace':e.font==='serif'?'Georgia':'Arial');
      const lines=e.txt.split('\n');lines.forEach((ln,li)=>{
        let tx=e.x;if((e.align||'left')==='center')tx=e.x+e.w/2;
        g.textAlign=e.align||'left';
        g.fillText(ln,tx,e.y+li*e.size*1.08);});res();}
    else if(e.t==='sticker'){g.font=e.size+'px serif';g.textBaseline='top';g.fillText(e.ch,e.x,e.y);res();}
    else if(e.t==='img'){const im=new Image();im.onload=()=>{g.drawImage(im,e.x,e.y,e.w,e.h);res()};im.onerror=res;im.src=e.src;}
    else if(e.t==='receipt'){
      g.fillStyle='#FAF7F2';g.fillRect(e.x,e.y,e.w,e.h);
      g.fillStyle='#14121F';g.textAlign='center';g.textBaseline='top';
      g.font='700 '+(e.w/16)+'px monospace';
      g.fillText('YOUR SHOP',e.x+e.w/2,e.y+e.w/12);
      g.fillText('BRISTOL',e.x+e.w/2,e.y+e.w/12+e.w/14);
      g.textAlign='left';g.font=(e.w/18)+'px monospace';
      const rows=[['Item','£1.45'],['Item','£2.30'],['TOTAL','£3.75']];
      rows.forEach((r2,ri)=>{g.fillText(r2[0],e.x+e.w/12,e.y+e.h*0.32+ri*e.w/10);
        g.textAlign='right';g.fillText(r2[1],e.x+e.w-e.w/12,e.y+e.h*0.32+ri*e.w/10);g.textAlign='left';});
      g.strokeStyle='#166534';g.lineWidth=3;g.strokeRect(e.x+e.w/10,e.y+e.h*0.7,e.w*0.8,e.h*0.14);
      g.fillStyle='#166534';g.textAlign='center';g.font='800 '+(e.w/17)+'px monospace';
      g.fillText('+37 POINTS',e.x+e.w/2,e.y+e.h*0.73);
      g.fillText('SAVED FOREVER',e.x+e.w/2,e.y+e.h*0.78);
      res();}
    else res();
  }));
  jobs.reduce((p2,j)=>p2.then(j),Promise.resolve()).then(()=>{
    const a=document.createElement('a');a.download='stashlo-design.png';a.href=c.toDataURL('image/png');a.click();
    window._LAST_PNG=a.href;
  });
}
function rr(g,x,y,w,h,r){g.beginPath();g.moveTo(x+r,y);g.arcTo(x+w,y,x+w,y+h,r);g.arcTo(x+w,y+h,x,y+h,r);g.arcTo(x,y+h,x,y,r);g.arcTo(x,y,x+w,y,r);g.closePath();}
function printIt(){
  const w=window.open('','_blank');if(!w){alert('Allow pop-ups to print');return}
  exportPNGto(png=>{
    const size=MMW?('size:'+MMW+'mm '+MMH+'mm;'):'';
    w.document.write('<html><head><style>@page{'+size+'margin:0}body{margin:0}img{width:100%;display:block}</style></head><body><img src="'+png+'" onload="setTimeout(()=>print(),300)"></body></html>');
    w.document.close();
  });
}
function exportPNGto(cb){
  const c=document.createElement('canvas');c.width=W*2;c.height=H*2;const g=c.getContext('2d');g.scale(2,2);
  g.fillStyle=BG;g.fillRect(0,0,W,H);
  exportPNG._silent=true;
  // reuse exportPNG job pipeline quickly: simple approach - call exportPNG logic inline via same code path is complex; draw again:
  const ev=EL.slice();let i=0;
  (function next(){
    if(i>=ev.length){cb(c.toDataURL('image/png'));return}
    const e=ev[i++];
    if(e.t==='img'){const im=new Image();im.onload=()=>{g.drawImage(im,e.x,e.y,e.w,e.h);next()};im.onerror=next;im.src=e.src;}
    else{const tmp=EL;/*draw same as exportPNG for non-img*/
      if(e.t==='rect'){g.fillStyle=e.fill;rr(g,e.x,e.y,e.w,e.h,e.r||0);g.fill();}
      else if(e.t==='circle'){g.fillStyle=e.fill;g.beginPath();g.ellipse(e.x+e.w/2,e.y+e.h/2,e.w/2,e.h/2,0,0,7);g.fill();}
      else if(e.t==='text'){g.fillStyle=e.color;g.textBaseline='top';g.font=(e.weight||700)+' '+e.size+'px '+(e.font==='mono'?'monospace':e.font==='serif'?'Georgia':'Arial');e.txt.split('\n').forEach((ln,li)=>{let tx=e.x;g.textAlign=e.align||'left';if((e.align||'left')==='center')tx=e.x+e.w/2;g.fillText(ln,tx,e.y+li*e.size*1.08);});}
      else if(e.t==='sticker'){g.font=e.size+'px serif';g.textBaseline='top';g.fillText(e.ch,e.x,e.y);}
      else if(e.t==='receipt'){g.fillStyle='#FAF7F2';g.fillRect(e.x,e.y,e.w,e.h);g.fillStyle='#14121F';g.textAlign='center';g.textBaseline='top';g.font='700 '+(e.w/16)+'px monospace';g.fillText('YOUR SHOP',e.x+e.w/2,e.y+e.w/12);}
      next();}
  })();
}

function exportGIF(){
  T_toast('Building GIF frames…');
  const load=cb=>{
    if(window.GIF)return cb();
    const s=document.createElement('script');
    s.src='https://cdnjs.cloudflare.com/ajax/libs/gif.js/0.2.0/gif.js';
    s.onload=cb;
    s.onerror=()=>alert('GIF export needs internet (loads one small library). PNG export works offline.');
    document.head.appendChild(s);
  };
  load(()=>{
    fetch('https://cdnjs.cloudflare.com/ajax/libs/gif.js/0.2.0/gif.worker.js').then(r=>r.text()).then(wk=>{
      const workerBlob=URL.createObjectURL(new Blob([wk],{type:'application/javascript'}));
      const scale=480/W, gw=480, gh=Math.round(H*scale);
      const gifr=new GIF({workers:2,quality:12,width:gw,height:gh,workerScript:workerBlob});
      const FR=14;
      const draws=[];
      for(let f=0;f<FR;f++){
        const c=document.createElement('canvas');c.width=gw;c.height=gh;
        const g2=c.getContext('2d');g2.scale(scale,scale);
        g2.fillStyle=BG;g2.fillRect(0,0,W,H);
        const t=f/(FR-1);
        EL.forEach((e,i)=>{
          const appear=Math.min(1,Math.max(0,(t*1.4)-(i/EL.length)*0.5)*3);
          if(appear<=0)return;
          g2.save();g2.globalAlpha=(e.op??1)*Math.min(1,appear);
          const pop=1+(1-Math.min(1,appear))*0.25;
          const w=e.w||(e.t==='sticker'?e.size:100), hh=e.h||(e.t==='sticker'?e.size:(e.t==='text'?e.size*1.2:100));
          g2.translate(e.x+w/2,e.y+hh/2);g2.scale(pop,pop);if(e.rot)g2.rotate(e.rot*Math.PI/180);g2.translate(-(e.x+w/2),-(e.y+hh/2));
          if(e.t==='rect'){g2.fillStyle=e.fill;rr(g2,e.x,e.y,e.w,e.h,e.r||0);g2.fill();}
          else if(e.t==='circle'){g2.fillStyle=e.fill;g2.beginPath();g2.ellipse(e.x+e.w/2,e.y+e.h/2,e.w/2,e.h/2,0,0,7);g2.fill();}
          else if(e.t==='text'){g2.fillStyle=e.color;g2.textBaseline='top';g2.font=(e.weight||700)+' '+e.size+'px '+(e.font==='mono'?'monospace':e.font==='serif'?'Georgia':'Arial');e.txt.split('\n').forEach((ln,li)=>{let tx=e.x;g2.textAlign=e.align||'left';if((e.align||'left')==='center')tx=e.x+e.w/2;g2.fillText(ln,tx,e.y+li*e.size*1.08);});}
          else if(e.t==='sticker'){g2.font=e.size+'px serif';g2.textBaseline='top';g2.fillText(e.ch,e.x,e.y);}
          else if(e.t==='img'&&e._el){g2.drawImage(e._el,e.x,e.y,e.w,e.h);}
          else if(e.t==='receipt'){g2.fillStyle='#FAF7F2';g2.fillRect(e.x,e.y,e.w,e.h);g2.fillStyle='#14121F';g2.textAlign='center';g2.textBaseline='top';g2.font='700 '+(e.w/16)+'px monospace';g2.fillText('YOUR SHOP',e.x+e.w/2,e.y+e.w/12);}
          g2.restore();
        });
        draws.push(c);
      }
      // preload imgs
      const imgs=EL.filter(e=>e.t==='img');
      Promise.all(imgs.map(e=>new Promise(res=>{const im=new Image();im.onload=()=>{e._el=im;res()};im.onerror=res;im.src=e.src;}))).then(()=>{
        // redraw frames now imgs cached? simple approach: rebuild frames including imgs
        draws.forEach((c,f)=>{
          const g2=c.getContext('2d');
          const t=f/(FR-1);
          imgs.forEach((e)=>{
            const i=EL.indexOf(e);
            const appear=Math.min(1,Math.max(0,(t*1.4)-(i/EL.length)*0.5)*3);
            if(appear<=0||!e._el)return;
            g2.save();g2.scale(scale,scale);g2.globalAlpha=(e.op??1)*Math.min(1,appear);
            g2.drawImage(e._el,e.x,e.y,e.w,e.h);g2.restore();
          });
          gifr.addFrame(c,{delay:f===FR-1?1200:70});
        });
        gifr.on('finished',blob=>{
          const a=document.createElement('a');a.download='stashlo-animated.gif';a.href=URL.createObjectURL(blob);a.click();
          T_toast('🎞 GIF saved — perfect for WhatsApp status');
        });
        gifr.render();
      });
    }).catch(()=>alert('GIF export needs internet. PNG works offline.'));
  });
}
function T_toast(m){let t=document.getElementById('sl-toast');if(!t){t=document.createElement('div');t.id='sl-toast';t.style.cssText='position:fixed;bottom:18px;left:50%;transform:translateX(-50%);background:#241f4d;border:1px solid #FBBF24;color:#fff;border-radius:12px;padding:10px 18px;font-size:13px;z-index:99';document.body.appendChild(t);}t.textContent=m;clearTimeout(t._h);t._h=setTimeout(()=>t.remove(),3500);}
