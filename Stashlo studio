<!DOCTYPE html><html lang="en"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Stashlo Studio — design for your shops</title>
<style>
:root{--ink:#14121F;--paper:#FAF7F2;--purple:#6366F1;--deep:#1e1b4b;--gold:#FBBF24;--bg:#0f0d23;--panel:#191536;--line:#2d2960}
*{margin:0;padding:0;box-sizing:border-box;font-family:-apple-system,'Segoe UI',Roboto,Arial,sans-serif}
body{background:var(--bg);color:#fff;height:100vh;display:flex;flex-direction:column;overflow:hidden}
header{display:flex;align-items:center;gap:10px;padding:9px 14px;background:var(--panel);border-bottom:1px solid var(--line)}
header b{font-size:16px}
header .sp{flex:1}
.tb{background:var(--purple);color:#fff;border:none;border-radius:9px;padding:9px 14px;font-weight:800;font-size:13px;cursor:pointer}
.tb.g{background:var(--gold);color:#151030}.tb.d{background:#2d2960}
main{flex:1;display:flex;min-height:0}
aside{width:230px;background:var(--panel);border-right:1px solid var(--line);overflow-y:auto;padding:10px}
aside h4{font-size:10px;letter-spacing:.14em;color:#8b89b8;margin:12px 4px 6px;text-transform:uppercase}
.tpl{background:#241f4d;border:1px solid var(--line);border-radius:10px;padding:8px;margin-bottom:6px;cursor:pointer;font-size:12px;font-weight:700}
.tpl small{display:block;color:#8b89b8;font-weight:400;font-size:10px}
.tools{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.tool{background:#241f4d;border:1px solid var(--line);border-radius:9px;padding:8px 4px;text-align:center;cursor:pointer;font-size:11px}
.tool span{display:block;font-size:16px}
.stick{display:grid;grid-template-columns:repeat(4,1fr);gap:4px}
.stick div{font-size:19px;text-align:center;cursor:pointer;background:#241f4d;border-radius:7px;padding:4px}
.artgrid{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.artgrid img{width:100%;border-radius:8px;cursor:pointer}
#stage-wrap{flex:1;display:flex;align-items:center;justify-content:center;overflow:auto;padding:20px;background:
 repeating-conic-gradient(#141130 0 25%,#0f0d23 0 50%) 0 0/22px 22px}
#stage{position:relative;background:#fff;box-shadow:0 14px 60px rgba(0,0,0,.6);transform-origin:center;flex-shrink:0}
.el{position:absolute;cursor:move;user-select:none}
.el.sel{outline:2px dashed var(--gold);outline-offset:2px}
.el .rz{position:absolute;right:-7px;bottom:-7px;width:14px;height:14px;background:var(--gold);border-radius:50%;cursor:nwse-resize;display:none}
.el.sel .rz{display:block}
.rightbar{width:225px;background:var(--panel);border-left:1px solid var(--line);padding:10px;overflow-y:auto}
.rightbar label{font-size:10px;color:#8b89b8;display:block;margin:9px 0 3px;letter-spacing:.1em;text-transform:uppercase}
.rightbar input[type=text],.rightbar textarea,.rightbar select{width:100%;background:#241f4d;border:1px solid var(--line);color:#fff;border-radius:8px;padding:7px;font-size:12px}
.rightbar input[type=color]{width:100%;height:32px;border:none;background:none;cursor:pointer}
.rightbar input[type=range]{width:100%}
.rowbtns{display:flex;gap:5px;margin-top:8px}
.rowbtns button{flex:1;background:#241f4d;border:1px solid var(--line);color:#fff;border-radius:8px;padding:7px 0;cursor:pointer;font-size:12px}
.hint{font-size:10px;color:#8b89b8;margin-top:12px;line-height:1.5}
#layers div{background:#241f4d;border-radius:7px;padding:5px 8px;font-size:11px;margin-bottom:4px;cursor:pointer;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
#layers div.on{background:var(--purple)}
@media(max-width:900px){aside{width:170px}.rightbar{width:180px}}
</style></head><body>
<header><b>💜 Stashlo Studio</b><span style="font-size:10px;color:#8b89b8">design for your shops · works offline</span><span class="sp"></span>
<button class="tb d" onclick="undo()">↩ Undo</button>
<button class="tb d" onclick="saveProject()">💾 Save</button>
<button class="tb d" onclick="loadProject()">📂 Open</button>
<button class="tb d" onclick="zoom(-.15)">−</button><button class="tb d" onclick="zoom(.15)">+</button><button class="tb d" onclick="exportGIF()">🎞 GIF</button><button class="tb" onclick="exportPNG(2)">⬇ PNG</button>
<button class="tb g" onclick="printIt()">🖨 Print / PDF</button>
</header>
<main>
<aside>
<h4>New from template</h4><div id="tpls"></div>
<h4>Add</h4>
<div class="tools">
<div class="tool" onclick="addText()"><span>🅣</span>Text</div>
<div class="tool" onclick="addEl({t:'rect',w:200,h:120,fill:'#6366F1',r:16})"><span>▭</span>Box</div>
<div class="tool" onclick="addEl({t:'circle',w:130,h:130,fill:'#FBBF24'})"><span>⬤</span>Circle</div>
<div class="tool" onclick="addReceipt()"><span>🧾</span>Receipt</div><div class="tool" onclick="uploadImage()" style="grid-column:1/3"><span>📷</span>Your photo / logo</div>
</div>
<h4>Your QR codes</h4><div id="qrlist"></div>
<h4>Product artwork</h4><div class="artgrid" id="arts"></div>
<h4>Stickers</h4>
<div class="stick" id="stickers"></div>
<div class="hint">Drag to move · corner dot resizes · double-click text to edit · Delete key removes</div>
</aside>
<div id="stage-wrap"><div id="stage"></div></div>
<div class="rightbar">
<label>Canvas background</label><input type="color" id="bgc" value="#1e1b4b" onchange="setBG(this.value)">
<div class="rowbtns">
<button onclick="setBG('#1e1b4b')" style="background:#1e1b4b">🌌</button>
<button onclick="setBG('#FAF7F2')" style="background:#FAF7F2"></button>
<button onclick="setBG('#065f46')" style="background:#065f46"></button>
<button onclick="setBG('#7f1d1d')" style="background:#7f1d1d"></button>
</div>
<div id="props"></div>
<label>Layers</label><div id="layers"></div>
<div class="rowbtns"><button onclick="layer(1)">⬆ Up</button><button onclick="layer(-1)">⬇ Down</button></div>
<div class="rowbtns"><button onclick="dupe()">⧉ Duplicate</button><button onclick="delSel()" style="background:#7f1d1d">🗑 Delete</button></div>
<div class="hint">Print sizes are exact — A4 poster prints as true A4. PNG export is 2× resolution for sharp WhatsApp/social posts.</div>
</div>
</main>
<script>
const ARTS={"headphones": "data:image/svg+xml;base64,", "earbuds": "data:image/svg+xml;base64,", "speaker": "data:image/svg+xml;base64,", "charger": "data:image/svg+xml;base64,", "powerbank": "data:image/svg+xml;base64,", "watch": "data:image/svg+xml;base64,", "bulb": "data:image/svg+xml;base64,", "cable": "data:image/svg+xml;base64,"};
const QRS={"Customer QR \u2014 stashlo.com": "data:image/png;base64,", "Merchant QR \u2014 /merchant": "data:image/png;base64,"};
let EL=[], SEL=-1, W=1240, H=1754, BG='#1e1b4b', HIST=[], SCALE=1, MMW=210, MMH=297;
const stage=document.getElementById('stage');

const TEMPLATES=[
 {n:'A4 Poster',s:'210×297mm print',w:1240,h:1754,mw:210,mh:297,bg:'#1e1b4b',els:[
   {t:'text',x:90,y:120,w:1060,txt:'BIG OFFER',size:130,weight:900,color:'#FBBF24',font:'sans'},
   {t:'text',x:90,y:290,w:1060,txt:'This weekend only at your local shop',size:44,weight:600,color:'#c7d2fe',font:'sans'},
   {t:'receipt',x:390,y:460,w:460,h:600},
   {t:'text',x:90,y:1560,w:800,txt:'💜 Stashlo · stashlo.com',size:40,weight:800,color:'#ffffff',font:'mono'}]},
 {n:'A5 Till Card',s:'148×210mm counter',w:874,h:1240,mw:148,mh:210,bg:'#1e1b4b',els:[
   {t:'text',x:60,y:90,w:754,txt:'Collect points\non this purchase',size:72,weight:900,color:'#ffffff',font:'sans'},
   {t:'img',x:262,y:380,w:350,h:350,src:Object.values(QRS)[0],label:'QR'},
   {t:'text',x:60,y:800,w:754,txt:'📱 SCAN ME — free, no app store',size:40,weight:800,color:'#FBBF24',font:'sans'}]},
 {n:'Instagram Post',s:'1080×1080',w:1080,h:1080,mw:0,mh:0,bg:'#FAF7F2',els:[
   {t:'rect',x:60,y:60,w:960,h:960,fill:'#1e1b4b',r:40},
   {t:'text',x:120,y:200,w:840,txt:'NEW IN\nTHE SHOP',size:110,weight:900,color:'#ffffff',font:'sans'},
   {t:'text',x:120,y:860,w:840,txt:'💜 stashlo.com',size:44,weight:800,color:'#FBBF24',font:'mono'}]},
 {n:'Story / Status',s:'1080×1920',w:1080,h:1920,mw:0,mh:0,bg:'#1e1b4b',els:[
   {t:'text',x:80,y:220,w:920,txt:'TODAY\nONLY',size:170,weight:900,color:'#FBBF24',font:'sans'},
   {t:'circle',x:340,y:760,w:400,h:400,fill:'#6366F1'},
   {t:'text',x:340,y:900,w:400,txt:'20% OFF',size:70,weight:900,color:'#fff',font:'sans',align:'center'}]},
 {n:'Price Tag',s:'800×500 shelf',w:800,h:500,mw:0,mh:0,bg:'#FAF7F2',els:[
   {t:'text',x:50,y:50,w:700,txt:'Coca-Cola 500ml',size:52,weight:800,color:'#14121F',font:'sans'},
   {t:'text',x:50,y:170,w:700,txt:'£1.50',size:170,weight:900,color:'#1e1b4b',font:'sans'},
   {t:'text',x:50,y:400,w:700,txt:'💎 earn 1 point at this shop',size:34,weight:700,color:'#6366F1',font:'sans'}]},
 {n:'Offer Banner',s:'1200×400 web/WhatsApp',w:1200,h:400,mw:0,mh:0,bg:'#065f46',els:[
   {t:'text',x:60,y:80,w:800,txt:'FRESH BREAD DAILY',size:80,weight:900,color:'#fff',font:'sans'},
   {t:'text',x:60,y:220,w:800,txt:'baked 7am · points on every loaf',size:40,weight:600,color:'#a7f3d0',font:'sans'}]},
 {n:'Opening Hours',s:'A4 door sign',w:1240,h:1754,mw:210,mh:297,bg:'#FAF7F2',els:[
   {t:'text',x:90,y:110,w:1060,txt:'OPENING\nHOURS',size:150,weight:900,color:'#1e1b4b',font:'sans'},
   {t:'text',x:90,y:520,w:1060,txt:'Mon–Fri   7am – 9pm\nSaturday  8am – 9pm\nSunday    9am – 6pm',size:64,weight:700,color:'#14121F',font:'mono'},
   {t:'text',x:90,y:1560,w:1000,txt:'💜 collect points here · stashlo.com',size:42,weight:800,color:'#6366F1',font:'sans'}]},
 {n:'We Deliver',s:'A4 window',w:1240,h:1754,mw:210,mh:297,bg:'#065f46',els:[
   {t:'sticker',x:480,y:120,ch:'🛵',size:280},
   {t:'text',x:90,y:480,w:1060,txt:'WE\nDELIVER',size:170,weight:900,color:'#ffffff',font:'sans'},
   {t:'text',x:90,y:980,w:1060,txt:'order from your sofa —\ntrack the driver to your door',size:56,weight:600,color:'#a7f3d0',font:'sans'},
   {t:'text',x:90,y:1560,w:1000,txt:'💜 stashlo.com',size:48,weight:800,color:'#FBBF24',font:'mono'}]},
 {n:'Now Hiring',s:'A4 job ad',w:1240,h:1754,mw:210,mh:297,bg:'#1e1b4b',els:[
   {t:'text',x:90,y:130,w:1060,txt:'NOW\nHIRING',size:180,weight:900,color:'#FBBF24',font:'sans'},
   {t:'text',x:90,y:640,w:1060,txt:'Part-time · friendly team\nask at the counter or apply\non the Stashlo app',size:60,weight:600,color:'#c7d2fe',font:'sans'}]},
 {n:'Blank A4',s:'start empty',w:1240,h:1754,mw:210,mh:297,bg:'#FAF7F2',els:[]}
];

function snap(){HIST.push(JSON.stringify({EL,BG,W,H}));if(HIST.length>50)HIST.shift();}
function undo(){if(!HIST.length)return;const s=JSON.parse(HIST.pop());EL=s.EL;BG=s.BG;W=s.W;H=s.H;SEL=-1;render();}
function fit(){const wr=document.getElementById('stage-wrap');SCALE=Math.min((wr.clientWidth-60)/W,(wr.clientHeight-60)/H,1);stage.style.transform='scale('+SCALE+')';}
function setBG(c){snap();BG=c;render();}
function loadTemplate(i){snap();const t=TEMPLATES[i];W=t.w;H=t.h;BG=t.bg;MMW=t.mw;MMH=t.mh;EL=JSON.parse(JSON.stringify(t.els));EL.forEach(e=>{e.x=e.x||0;e.y=e.y||0});SEL=-1;render();fit();}
function addEl(e){snap();e.x=e.x??W/2-((e.w||100)/2);e.y=e.y??H/2-((e.h||100)/2);EL.push(e);SEL=EL.length-1;render();}
function addText(){addEl({t:'text',w:Math.min(600,W-100),txt:'Double-click to edit',size:60,weight:800,color:BG==='#FAF7F2'?'#14121F':'#ffffff',font:'sans'});}
function addReceipt(){addEl({t:'receipt',w:420,h:560});}
function addImg(src,label){addEl({t:'img',w:300,h:300,src,label:label||'image'});}

function render(){
  stage.style.width=W+'px';stage.style.height=H+'px';stage.style.background=BG;
  stage.innerHTML='';
  EL.forEach((e,i)=>{
    const d=document.createElement('div');d.className='el'+(i===SEL?' sel':'');d.dataset.i=i;
    d.style.left=e.x+'px';d.style.top=e.y+'px';
    if(e.rot)d.style.transform='rotate('+e.rot+'deg)';
    if(e.op!==undefined&&e.op<1)d.style.opacity=e.op;
    if(e.shadow)d.style.filter='drop-shadow(0 8px 18px rgba(0,0,0,.45))';
    if(e.t==='text'){
      d.style.width=e.w+'px';
      d.style.font=(e.weight||700)+' '+e.size+'px '+(e.font==='mono'?"ui-monospace,'Courier New',monospace":e.font==='serif'?'Georgia,serif':'-apple-system,Arial,sans-serif');
      d.style.color=e.color;d.style.lineHeight=1.08;d.style.whiteSpace='pre-wrap';
      d.style.textAlign=e.align||'left';
      d.textContent=e.txt;
    }else if(e.t==='rect'){d.style.width=e.w+'px';d.style.height=e.h+'px';d.style.background=e.fill;d.style.borderRadius=(e.r||0)+'px';}
    else if(e.t==='circle'){d.style.width=e.w+'px';d.style.height=e.h+'px';d.style.background=e.fill;d.style.borderRadius='50%';}
    else if(e.t==='img'){const im=document.createElement('img');im.src=e.src;im.style.width=e.w+'px';im.style.height=e.h+'px';im.style.objectFit='contain';im.draggable=false;d.appendChild(im);}
    else if(e.t==='sticker'){d.style.fontSize=e.size+'px';d.textContent=e.ch;}
    else if(e.t==='receipt'){
      d.style.width=e.w+'px';d.style.height=e.h+'px';d.style.background='#FAF7F2';d.style.color='#14121F';
      d.style.fontFamily="ui-monospace,'Courier New',monospace";d.style.fontSize=(e.w/16)+'px';d.style.padding=(e.w/12)+'px';
      d.style.clipPath='polygon(0 0,100% 0,100% 96%,90% 100%,80% 96%,70% 100%,60% 96%,50% 100%,40% 96%,30% 100%,20% 96%,10% 100%,0 96%)';
      d.innerHTML='<div style="text-align:center;font-weight:700;letter-spacing:.1em">YOUR SHOP<br>BRISTOL</div><hr style="border:0;border-top:1px dashed #cbc5bb;margin:8% 0"><div style="display:flex;justify-content:space-between"><span>Item</span><b>£1.45</b></div><div style="display:flex;justify-content:space-between"><span>Item</span><b>£2.30</b></div><div style="display:flex;justify-content:space-between"><span>TOTAL</span><b>£3.75</b></div><div style="margin-top:10%;text-align:center;font-weight:800;color:#166534;border:2px solid #166534;border-radius:8px;padding:4%;transform:rotate(-2deg)">+37 POINTS · SAVED FOREVER</div>';
    }
    const rz=document.createElement('div');rz.className='rz';d.appendChild(rz);
    stage.appendChild(d);
  });
  renderLayers();renderProps();
}
function renderLayers(){
  document.getElementById('layers').innerHTML=EL.map((e,i)=>'<div class="'+(i===SEL?'on':'')+'" onclick="SEL='+i+';render()">'+
    (e.t==='text'?'🅣 '+e.txt.slice(0,16):e.t==='img'?'🖼 '+(e.label||'image'):e.t==='sticker'?e.ch:e.t==='receipt'?'🧾 receipt':(e.t==='rect'?'▭':'⬤')+' shape')+'</div>').reverse().join('');
}
function renderProps(){
  const p=document.getElementById('props');const e=EL[SEL];
  if(!e){p.innerHTML='<label>Nothing selected</label>';return}
  let h='';
  if(e.t==='text'){
    h+='<label>Text</label><textarea rows=3 oninput="EL[SEL].txt=this.value;render()">'+e.txt+'</textarea>';
    h+='<label>Size '+e.size+'px</label><input type=range min=16 max=260 value='+e.size+' oninput="EL[SEL].size=+this.value;render()">';
    h+='<label>Colour</label><input type=color value='+e.color+' onchange="EL[SEL].color=this.value;render()">';
    h+='<label>Font</label><select onchange="EL[SEL].font=this.value;render()"><option value=sans'+(e.font==='sans'?' selected':'')+'>Modern</option><option value=mono'+(e.font==='mono'?' selected':'')+'>Receipt mono</option><option value=serif'+(e.font==='serif'?' selected':'')+'>Serif</option></select>';
    h+='<label>Weight</label><select onchange="EL[SEL].weight=+this.value;render()"><option value=400'+(e.weight===400?' selected':'')+'>Regular</option><option value=700'+(e.weight===700?' selected':'')+'>Bold</option><option value=900'+(e.weight===900?' selected':'')+'>Black</option></select>';
  }
  if(e.t==='rect'||e.t==='circle'){h+='<label>Fill</label><input type=color value='+e.fill+' onchange="EL[SEL].fill=this.value;render()">';
    if(e.t==='rect')h+='<label>Corner '+(e.r||0)+'px</label><input type=range min=0 max=80 value='+(e.r||0)+' oninput="EL[SEL].r=+this.value;render()">';}
  h+='<label>Rotate '+(e.rot||0)+'°</label><input type=range min=-180 max=180 value='+(e.rot||0)+' oninput="EL[SEL].rot=+this.value;render()">';
  h+='<label>Opacity</label><input type=range min=10 max=100 value='+Math.round((e.op??1)*100)+' oninput="EL[SEL].op=+this.value/100;render()">';
  h+='<label><input type=checkbox '+(e.shadow?'checked':'')+' onchange="EL[SEL].shadow=this.checked;render()"> Drop shadow</label>';
  h+='<div class="rowbtns"><button onclick="alignEl(\'h\')">↔ Centre</button><button onclick="alignEl(\'v\')">↕ Middle</button></div>';
  if(e.t==='sticker')h+='<label>Size ' +e.size+'px</label><input type=range min=30 max=300 value='+e.size+' oninput="EL[SEL].size=+this.value;render()">';
  p.innerHTML=h;
}
function layer(d){if(SEL<0)return;const j=SEL+d;if(j<0||j>=EL.length)return;snap();[EL[SEL],EL[j]]=[EL[j],EL[SEL]];SEL=j;render();}
function dupe(){if(SEL<0)return;snap();const c=JSON.parse(JSON.stringify(EL[SEL]));c.x+=30;c.y+=30;EL.push(c);SEL=EL.length-1;render();}
function delSel(){if(SEL<0)return;snap();EL.splice(SEL,1);SEL=-1;render();}

let drag=null;
stage.addEventListener('pointerdown',ev=>{
  const el=ev.target.closest('.el');if(!el){SEL=-1;render();return}
  SEL=+el.dataset.i;render();
  const e=EL[SEL];
  if(ev.target.classList.contains('rz')){drag={rz:true,sx:ev.clientX,sy:ev.clientY,w:e.w||100,h:e.h||100,size:e.size};}
  else drag={sx:ev.clientX,sy:ev.clientY,x:e.x,y:e.y};
  snap();
});
window.addEventListener('pointermove',ev=>{
  if(!drag||SEL<0)return;const e=EL[SEL];
  const dx=(ev.clientX-drag.sx)/SCALE, dy=(ev.clientY-drag.sy)/SCALE;
  if(drag.rz){
    if(e.t==='text'){e.size=Math.max(16,Math.round(drag.size+dx/2));}
    else if(e.t==='sticker'){e.size=Math.max(30,Math.round(drag.size+dx));}
    else{e.w=Math.max(30,Math.round(drag.w+dx));e.h=Math.max(30,Math.round(drag.h+dy));}
  }else{
    e.x=Math.round(drag.x+dx);e.y=Math.round(drag.y+dy);
    const w=e.w||(e.t==='sticker'?e.size:100), hh=e.h||(e.t==='sticker'?e.size:(e.t==='text'?e.size*1.2:100));
    const cx=W/2-w/2, cy=H/2-hh/2; let snapOn=false;
    if(Math.abs(e.x-cx)<14){e.x=Math.round(cx);snapOn=true}
    if(Math.abs(e.y-cy)<14){e.y=Math.round(cy);snapOn=true}
    render(); drawGuides(snapOn); return;
  }
  render();
});
window.addEventListener('pointerup',()=>{drag=null;drawGuides(false);});
stage.addEventListener('dblclick',ev=>{
  const el=ev.target.closest('.el');if(!el)return;const e=EL[+el.dataset.i];
  if(e.t==='text'){const t=prompt('Edit text:',e.txt);if(t!==null){snap();e.txt=t;render();}}
});
window.addEventListener('keydown',ev=>{
  if((ev.key==='Delete'||ev.key==='Backspace')&&SEL>=0&&!/TEXTAREA|INPUT/.test(document.activeElement.tagName)){ev.preventDefault();delSel();}
});


function alignEl(dir){if(SEL<0)return;const e=EL[SEL];snap();
  const w=e.w||(e.t==='sticker'?e.size:100), hh=e.h||(e.t==='sticker'?e.size:(e.t==='text'?e.size*1.2:100));
  if(dir==='h')e.x=Math.round((W-w)/2); else e.y=Math.round((H-hh)/2);
  render();}
function uploadImage(){
  const inp=document.createElement('input');inp.type='file';inp.accept='image/*';
  inp.onchange=()=>{const f=inp.files[0];if(!f)return;
    if(f.size>4*1024*1024){alert('Max 4MB');return}
    const r=new FileReader();
    r.onload=()=>{const im=new Image();im.onload=()=>{
      const maxW=Math.min(500,W*.6), sc=Math.min(1,maxW/im.width);
      addImg(r.result,f.name.slice(0,14)); const e=EL[EL.length-1];
      e.w=Math.round(im.width*sc); e.h=Math.round(im.height*sc); render();
    };im.src=r.result;};
    r.readAsDataURL(f);};
  inp.click();}
